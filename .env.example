# Copy this file to .env and fill in real values

# APPLICATION
PORT=4000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# JWT
JWT_SECRET=generate_with_node_crypto_randomBytes_48
JWT_EXPIRES_IN=8h

# DATABASE (Supabase)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require

# REDIS (Upstash)
REDIS_HOST=your-redis.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your_upstash_redis_password

# PAYSTACK
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key

# SMS (Arkesel)
ARKESEL_API_KEY=your_arkesel_api_key
ARKESEL_SENDER_ID=HGL

# STORAGE (Supabase S3)
STORAGE_ENDPOINT=https://<project-ref>.storage.supabase.co/storage/v1/s3
STORAGE_BUCKET=cdg-receipts
STORAGE_ACCESS_KEY_ID=your_supabase_s3_access_key_id
STORAGE_SECRET_ACCESS_KEY=your_supabase_s3_secret_access_key
STORAGE_REGION=auto
